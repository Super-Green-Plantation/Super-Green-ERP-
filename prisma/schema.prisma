generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model Branch {
  name        String
  location    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  id          Int            @id @default(autoincrement())
  status      Status         @default(Active)
  parentId    Int?
  ActivityLog ActivityLog[]
  parent      Branch?        @relation("BranchHierarchy", fields: [parentId], references: [id])
  children    Branch[]       @relation("BranchHierarchy")
  client      Client[]
  commission  Commission[]
  investments Investment[]
  members     MemberBranch[]
}

model Position {
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  id              Int              @id @default(autoincrement())
  title           Title
  rank            Int              @unique
  isManagement    Boolean          @default(false)
  isProbation     Boolean          @default(false)
  type            PositionType     @default(PROBATION)
  orc             CommissionRate?
  members         Member[]
  salary          PositionSalary?
  positionTargets PositionTarget[]
}

model CommissionRate {
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  id               Int      @id @default(autoincrement())
  positionId       Int      @unique
  rateNonPermanent Float    @default(0)
  ratePermanent    Float    @default(0)
  position         Position @relation(fields: [positionId], references: [id])
}

model MemberBranch {
  id       Int    @id @default(autoincrement())
  memberId Int
  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, branchId])
}

model MonthlyPayroll {
  id                   Int      @id @default(autoincrement())
  memberId             Int
  year                 Int
  month                Int
  volumeAchieved       Float    @default(0)
  monthlyTarget        Float
  incentiveEarned      Float    @default(0)
  allowanceEarned      Float    @default(0)
  orcEarned            Float    @default(0)
  commissionEarned     Float    @default(0)
  epfDeduction         Float    @default(0)
  epfEmployer          Float    @default(0)
  etfEmployer          Float    @default(0)
  incentiveHit         Boolean  @default(false)
  allowanceHit         Boolean  @default(false)
  grossPay             Float    @default(0)
  netPay               Float    @default(0)
  createdAt            DateTime @default(now())
  basicSalaryPermanent Float    @default(0)
  member               Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, year, month])
}

model PositionSalary {
  id                          Int      @id @default(autoincrement())
  positionId                  Int      @unique
  monthlyTarget               Float
  incentiveAmount             Float
  allowanceAmount             Float
  commRateLow                 Float
  commRateHigh                Float
  commThreshold               Float    @default(500000)
  epfEmployee                 Float    @default(0.08)
  epfEmployer                 Float    @default(0.12)
  etfEmployer                 Float    @default(0.03)
  allowanceThresholdPermanent Float    @default(1.0)
  allowanceThresholdProbation Float    @default(0.75)
  basicSalaryPermanent        Float    @default(0)
  basicSalaryProbation        Float    @default(0)
  position                    Position @relation(fields: [positionId], references: [id])
}

model Member {
  totalCommission        Float               @default(0)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime?
  id                     Int                 @id @default(autoincrement())
  positionId             Int
  empNo                  String              @unique
  email                  String?             @unique
  phone                  String?
  userId                 String?             @unique @db.Uuid
  accNo                  String?
  address                String?
  appointmentLetter      String?
  bank                   String?
  bankBranch             String?
  civilStatus            String?
  confirmation           String?
  dateOfJoin             DateTime?
  dob                    DateTime?
  gender                 String?
  nameWithInitials       String?
  nic                    String?
  remark                 String?
  probationStartDate     String?
  profilePic             String?
  status                 EmployeeStatus      @default(PROBATION)
  epfNo                  String?
  phone2                 String?
  lastClientRegisteredAt DateTime?
  reportingPersons       String[]
  etfNo                  String?
  isActive               Boolean             @default(true)
  channel                Channel             @default(Chanel_01)
  activityLog            ActivityLog[]
  createdClients         Client[]            @relation("CreatedByMember")
  clients                Client[]
  commissions            Commission[]
  advisorInvestments     Investment[]        @relation("AdvisorInvestments")
  position               Position            @relation(fields: [positionId], references: [id])
  user                   User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  branches               MemberBranch[]
  monthlyEvaluations     MonthlyEvaluation[]
  monthlyPayrolls        MonthlyPayroll[]

  clientsAsFA  Client[] @relation("ClientFA")
  clientsAsFM  Client[] @relation("ClientFM")
  clientsAsBM  Client[] @relation("ClientBM")
  clientsAsRM  Client[] @relation("ClientRM")
  clientsAsZM  Client[] @relation("ClientZM")
  clientsAsAGM Client[] @relation("ClientAGM")
  clientsAsCCO Client[] @relation("ClientCCO")
}

model PositionTarget {
  id                     Int      @id @default(autoincrement())
  positionId             Int
  periodNumber           Int
  monthNumber            Int
  targetAmount           Float
  bonusAmount            Float
  excessRate             Float    @default(0)
  partialBonus           Float    @default(0)
  partialThreshold       Float    @default(0)
  bonusThresholdPct      Float    @default(1.0)
  minActiveAdvisors      Int      @default(0)
  minActiveBMs           Int      @default(0)
  minActiveFMs           Int      @default(0)
  teamActiveAmount       Float    @default(0)
  teamActiveThresholdPct Float    @default(0)
  vehicleAmount          Float    @default(0)
  vehicleThresholdPct    Float    @default(0)
  after6MonthTarget      Float    @default(0)
  position               Position @relation(fields: [positionId], references: [id])

  @@unique([positionId, periodNumber, monthNumber])
}

model MonthlyEvaluation {
  id             Int      @id @default(autoincrement())
  memberId       Int
  year           Int
  month          Int
  periodNumber   Int?
  monthInPeriod  Int?
  volumeAchieved Float
  targetAmount   Float
  bonusEarned    Float    @default(0)
  excessBonus    Float    @default(0)
  targetHit      Boolean  @default(false)
  createdAt      DateTime @default(now())
  member         Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, year, month])
}

model FinancialPlan {
  id          Int          @id @default(autoincrement())
  name        String
  duration    Int
  description String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  status      Status       @default(Active)
  investment  Float?
  rate        Float[]
  investments Investment[]
}

model Investment {
  id                   Int            @id @default(autoincrement())
  investmentDate       DateTime
  amount               Float
  clientId             Int
  planId               Int?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  advisorId            Int?
  commissionsProcessed Boolean        @default(false)
  refNumber            String?
  branchId             Int
  beneficiaryId        Int?
  nomineeId            Int?
  isMatured            Boolean        @default(false)
  maturityDate         DateTime?
  maturityNotified     Boolean        @default(false)
  monthlyHarvest       Float?
  totalHarvest         Float?
  proposalFormNo       String?        @unique(where: raw("(\"proposalFormNo\" IS NOT NULL)"))
  proposal             String?
  agreement            String?
  paymentSlip          String?
  investmentRates      Float[]        @default([])
  status               InvStatus      @default(Active)
  commission           Commission[]
  advisor              Member?        @relation("AdvisorInvestments", fields: [advisorId], references: [id])
  beneficiary          Beneficiary?   @relation(fields: [beneficiaryId], references: [id])
  branch               Branch         @relation(fields: [branchId], references: [id])
  client               Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  nominee              Nominee?       @relation(fields: [nomineeId], references: [id])
  plan                 FinancialPlan? @relation(fields: [planId], references: [id])
  profit               Profit?
}

model Client {
  id                    Int                     @id @default(autoincrement())
  email                 String?                 @unique
  address               String
  branchId              Int
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  dateOfBirth           DateTime?
  drivingLicense        String?                 @unique
  fullName              String
  nic                   String?                 @unique
  occupation            String?
  passportNo            String?                 @unique
  phoneLand             String?
  phoneMobile           String?
  status                Status                  @default(Active)
  idBack                String?
  idFront               String?
  signature             String?
  memberId              Int?
  createdById           Int?
  beneficiaries         Beneficiary[]
  branch                Branch                  @relation(fields: [branchId], references: [id])
  createdBy             Member?                 @relation("CreatedByMember", fields: [createdById], references: [id])
  member                Member?                 @relation(fields: [memberId], references: [id], onDelete: Cascade)
  ClientDocumentRequest ClientDocumentRequest[]
  investments           Investment[]
  nominees              Nominee[]

  faId  Int?
  fmId  Int?
  bmId  Int?
  rmId  Int?
  zmId  Int?
  agmId Int?
  ccoId Int?

  fa  Member? @relation("ClientFA", fields: [faId], references: [id])
  fm  Member? @relation("ClientFM", fields: [fmId], references: [id])
  bm  Member? @relation("ClientBM", fields: [bmId], references: [id])
  rm  Member? @relation("ClientRM", fields: [rmId], references: [id])
  zm  Member? @relation("ClientZM", fields: [zmId], references: [id])
  agm Member? @relation("ClientAGM", fields: [agmId], references: [id])
  cco Member? @relation("ClientCCO", fields: [ccoId], references: [id])
}

model Beneficiary {
  id           Int          @id @default(autoincrement())
  fullName     String
  nic          String?
  phone        String
  bankName     String
  bankBranch   String
  accountNo    String
  relationship String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  clientId     Int
  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  investments  Investment[]
}

model Nominee {
  id               Int          @id @default(autoincrement())
  fullName         String
  permanentAddress String
  postalAddress    String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  clientId         Int
  nic              String?
  investments      Investment[]
  client           Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Commission {
  id           Int            @id @default(autoincrement())
  investmentId Int
  memberEmpNo  String
  amount       Float
  type         CommissionType
  createdAt    DateTime       @default(now())
  refNumber    String?        @unique
  branchId     Int
  Branch       Branch         @relation(fields: [branchId], references: [id])
  investment   Investment     @relation(fields: [investmentId], references: [id], onDelete: Cascade)
  member       Member         @relation(fields: [memberEmpNo], references: [empNo], onDelete: Cascade)

  @@index([investmentId])
  @@index([memberEmpNo])
}

model Profit {
  id               Int        @id @default(autoincrement())
  investmentId     Int        @unique
  investmentAmount Float      @default(0)
  commissionPayout Float      @default(0)
  totalProfit      Float      @default(0)
  investment       Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id            Int            @id @default(autoincrement())
  action        ActivityAction
  entity        ActivityEntity
  entityId      Int?
  performedById Int?
  branchId      Int?
  metadata      Json?
  createdAt     DateTime       @default(now())
  branch        Branch?        @relation(fields: [branchId], references: [id])
  performedBy   Member?        @relation(fields: [performedById], references: [id], onDelete: Cascade)

  @@index([entity, entityId])
  @@index([performedById])
  @@index([branchId])
}

model User {
  role                  Role                    @default(EMPLOYEE)
  branchId              Int?
  status                Boolean                 @default(true)
  email                 String?                 @unique
  name                  String?
  id                    String                  @id @default(uuid()) @db.Uuid
  lastLoginAt           DateTime?               @default(now())
  ClientDocumentRequest ClientDocumentRequest[]
  member                Member?
  quotations            Quotation[]
}

model ClientDocumentRequest {
  id          Int              @id @default(autoincrement())
  clientId    Int
  token       String           @unique
  createdById String           @db.Uuid
  expiresAt   DateTime
  used        Boolean          @default(false)
  createdAt   DateTime         @default(now())
  documents   ClientDocument[]
  client      Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy   User             @relation(fields: [createdById], references: [id], onDelete: Cascade)
}

model ClientDocument {
  id         Int                   @id @default(autoincrement())
  requestId  Int
  idFront    String?
  idBack     String?
  uploadedAt DateTime              @default(now())
  request    ClientDocumentRequest @relation(fields: [requestId], references: [id])
}

model Quotation {
  id                String             @id @default(cuid())
  clientName        String
  clientNic         String?
  clientAge         Int?
  planType          QuotationPlanType
  frequency         QuotationFrequency
  duration          Int
  premium           Float
  retirementAge     Int?
  totalInvested     Float
  interestRate      Float
  interestEarned    Float
  maturityAmount    Float
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  createdByUserId   String             @db.Uuid
  documentCharge    Float              @default(500)
  netInterestEarned Float
  netMaturityAmount Float
  createdBy         User               @relation(fields: [createdByUserId], references: [id])

  @@index([createdByUserId])
  @@index([planType])
  @@index([createdAt])
}

enum Status {
  Active
  Inactive
}

enum ReturnFrequency {
  Monthly
  HalfYearly
  Yearly
}

enum Title {
  ADMIN
  CHAIRMEN
  HR
  ACC
  IT
  ABM
  PRO
  OPM
  CLEANING
  FA
  TL
  BM
  RM
  ZM
  PRO_AGM
  TRAINEE_FA
  P_FA
  P_TL
  JBM
  SBM
  JRM
  SRM
  JZM
  SZM
  PER_AGM
  COO
  DGM
  GM
  SE
}

enum PositionType {
  PROBATION
  PERMANENT
  MANAGEMENT
}

enum EmployeeStatus {
  PROBATION
  PERMANENT
  MANAGEMENT
}

enum Channel {
  Chanel_01
  Chanel_02
  Micro
}

enum InvStatus {
  Active
  Inactive
  Renew
}

enum CommissionType {
  PERSONAL
  UPLINE
}

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  LOGIN
}

enum ActivityEntity {
  CLIENT
  INVESTMENT
  COMMISSION
  PROFIT
  MEMBER
  BRANCH
  FINANCIAL_PLAN
}

enum Role {
  ADMIN
  HR
  DEV
  BRANCH_MANAGER
  REGIONAL_MANAGER
  AGM
  EMPLOYEE
  ZONAL_MANAGER
}

enum QuotationPlanType {
  CHILD
  MARGE
  PENSION
}

enum QuotationFrequency {
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
}
