generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  Active
  Inactive
}

enum ReturnFrequency {
  Monthly
  HalfYearly
  Yearly
}

model Branch {
  id          Int            @id @default(autoincrement())
  name        String
  location    String?
  // members     Member[]
  members     MemberBranch[]
  status      Status         @default(Active)
  client      Client[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  ActivityLog ActivityLog[]
  investments Investment[]
  commission  Commission[]
}

enum Title {
  AGM
  ZM
  RM
  BM
  TL
  FA
}

model Position {
  id         Int   @id @default(autoincrement())
  title      Title
  baseSalary Float
  rank       Int   @unique

  orc CommissionRate?

  members Member[]

  personalCommissionTiers PersonalCommissionTier[]

  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  positionTargets         PositionTarget[]
  positionPermanentTarget PositionPermanentTarget?
  salary           PositionSalary?
}

model CommissionRate {
  id         Int      @id @default(autoincrement())
  rate       Decimal?
  position   Position @relation(fields: [positionId], references: [id])
  positionId Int      @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PersonalCommissionTier {
  id         Int     @id @default(autoincrement())
  positionId Int
  minAmount  Float
  maxAmount  Float? // null = no upper limit
  rate       Decimal

  position Position @relation(fields: [positionId], references: [id])

  @@index([positionId])
}

//Junction Table
model MemberBranch {
  id Int @id @default(autoincrement())

  memberId Int
  branchId Int

  member Member @relation(fields: [memberId], references: [id])
  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([memberId, branchId])
}

enum EmployeeStatus {
  PROBATION
  PERMANENT
}

model PositionPermanentTarget {
  id         Int      @id @default(autoincrement())
  positionId Int      @unique
  position   Position @relation(fields: [positionId], references: [id])

  monthlyTarget      Float // e.g. 4_000_000
  incentiveThreshold Float // e.g. 0.25 (25%)
  incentiveAmount    Float // fixed amount paid when hit
  allowanceThreshold Float // e.g. 0.75 (75%)
  allowanceAmount    Float // fixed amount paid when hit
}

model PermanentEvaluation {
  id              Int      @id @default(autoincrement())
  memberId        Int
  member          Member   @relation(fields: [memberId], references: [id])
  year            Int
  month           Int
  volumeAchieved  Float
  monthlyTarget   Float // snapshot
  incentiveEarned Float    @default(0)
  allowanceEarned Float    @default(0)
  incentiveHit    Boolean  @default(false)
  allowanceHit    Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@unique([memberId, year, month])
}

model PositionSalary {
  id         Int      @id @default(autoincrement())
  positionId Int      @unique
  position   Position @relation(fields: [positionId], references: [id])

  basicSalary     Float // e.g. 30000
  monthlyTarget   Float // e.g. 3_000_000
  incentiveAmount Float // paid at 100% target
  allowanceAmount Float // paid at 75% target
  orcRate         Float @default(0) // e.g. 0.01 for 1%
  commRateLow     Float // e.g. 0.05 for probation=0.07
  commRateHigh    Float // e.g. 0.08 for probation=0.10
  commThreshold   Float @default(500000)

  epfEmployee Float @default(0.08)
  epfEmployer Float @default(0.12)
  etfEmployer Float @default(0.03)
}

model MonthlyPayroll {
  id       Int    @id @default(autoincrement())
  memberId Int
  member   Member @relation(fields: [memberId], references: [id])
  year     Int
  month    Int

  basicSalary    Float
  volumeAchieved Float @default(0)
  monthlyTarget  Float

  incentiveEarned  Float @default(0)
  allowanceEarned  Float @default(0)
  orcEarned        Float @default(0)
  commissionEarned Float @default(0)

  epfDeduction Float @default(0) // employee 8% of basic
  epfEmployer  Float @default(0) // employer 12% of basic
  etfEmployer  Float @default(0) // employer 3% of basic

  incentiveHit Boolean @default(false)
  allowanceHit Boolean @default(false)

  grossPay Float @default(0) // basic + incentive + allowance + orc + commission
  netPay   Float @default(0) // grossPay - epfDeduction

  createdAt DateTime @default(now())

  @@unique([memberId, year, month])
}

//many side ekata foreign key eka / Parent has an array
model Member {
  id                Int       @id @default(autoincrement())
  nameWithInitials  String?
  email             String?   @unique
  empNo             String    @unique
  phone             String?
  nic               String?
  dob               DateTime?
  birthday          DateTime?
  gender            String?
  civilStatus       String?
  address           String?
  reportingPerson   String?
  dateOfJoin        DateTime?
  appointmentLetter String?
  confirmation      String?
  remark            String?
  accNo             String?
  bank              String?
  bankBranch        String?
  totalCommission   Float     @default(0)
  profilePic        String?

  userId String? @unique @db.Uuid
  user   User?   @relation(fields: [userId], references: [id])

  status             EmployeeStatus @default(PROBATION)
  probationStartDate DateTime?

  positionId Int
  position   Position @relation(fields: [positionId], references: [id])

  branches    MemberBranch[]
  commissions Commission[]
  investments Investment[]
  activityLog ActivityLog[]
  clients     Client[]

  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  monthlyEvaluations   MonthlyEvaluation[]
  permanentEvaluations PermanentEvaluation[]
  monthlyPayrolls      MonthlyPayroll[]
}

model PositionTarget {
  id               Int      @id @default(autoincrement())
  positionId       Int
  position         Position @relation(fields: [positionId], references: [id])
  periodNumber     Int // 1 = first 3 months, 2 = second 3 months
  monthNumber      Int // 1, 2, or 3 within that period
  targetAmount     Float // e.g. 1_500_000
  bonusAmount      Float // fixed bonus if target hit, e.g. 50_000
  excessRate       Float    @default(0) // 0 for period 1, 0.005 for period 2
  partialThreshold Float    @default(0)
  partialBonus     Float    @default(0)

  @@unique([positionId, periodNumber, monthNumber])
}

model MonthlyEvaluation {
  id             Int      @id @default(autoincrement())
  memberId       Int
  member         Member   @relation(fields: [memberId], references: [id])
  year           Int
  month          Int // 1–12
  periodNumber   Int? // 1 or 2 during probation, null if permanent
  monthInPeriod  Int? // 1, 2, 3 within period
  volumeAchieved Float
  targetAmount   Float // snapshot at time of eval
  bonusEarned    Float    @default(0)
  excessBonus    Float    @default(0)
  targetHit      Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@unique([memberId, year, month])
}

model FinancialPlan {
  id          Int          @id @default(autoincrement())
  name        String
  duration    Int // months
  rate        Float
  description String
  status      Status       @default(Active)
  investment  Float?
  investments Investment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id Int @id @default(autoincrement())

  fullName       String
  nic            String? @unique
  drivingLicense String? @unique
  passportNo     String? @unique

  email       String? @unique
  phoneMobile String?
  phoneLand   String?

  memberId Int? // optional for existing clients
  member   Member? @relation(fields: [memberId], references: [id])

  dateOfBirth DateTime?
  occupation  String?

  address          String
  investmentAmount Int

  signature   String?
  idFront     String?
  idBack      String?
  paymentSlip String?
  proposal    String?
  agreement   String?

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id])

  status Status @default(Active)

  investments Investment[]
  beneficiary Beneficiary?
  nominee     Nominee?

  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  ClientDocumentRequest ClientDocumentRequest[]
}

model Beneficiary {
  id Int @id @default(autoincrement())

  fullName String
  nic      String?
  phone    String

  bankName   String
  bankBranch String
  accountNo  String

  relationship String

  clientId Int    @unique
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Nominee {
  id Int @id @default(autoincrement())

  fullName         String
  permanentAddress String
  postalAddress    String?

  clientId Int    @unique
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Investment {
  id             Int      @id @default(autoincrement())
  refNumber      String?
  investmentDate DateTime
  amount         Float

  clientId Int
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id])

  planId Int?
  plan   FinancialPlan? @relation(fields: [planId], references: [id])

  advisorId Int?
  advisor   Member? @relation(fields: [advisorId], references: [id])

  commission Commission[]

  profit Profit? // optional is safer 

  commissionsProcessed Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Commission {
  id           Int     @id @default(autoincrement())
  refNumber    String? @unique // Optional for now to support existing data
  investmentId Int
  memberEmpNo  String
  branchId     Int

  amount    Float
  type      CommissionType
  createdAt DateTime       @default(now())

  member     Member     @relation(fields: [memberEmpNo], references: [empNo])
  investment Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)
  Branch     Branch     @relation(fields: [branchId], references: [id])

  @@index([investmentId])
  @@index([memberEmpNo])
}

enum CommissionType {
  PERSONAL
  UPLINE
}

model Profit {
  id Int @id @default(autoincrement())

  investmentId Int        @unique
  investment   Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  investmentAmount Float @default(0)
  commissionPayout Float @default(0)
  totalProfit      Float @default(0)
}

//activity log

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  LOGIN
}

enum ActivityEntity {
  CLIENT
  INVESTMENT
  COMMISSION
  PROFIT
  MEMBER
}

model ActivityLog {
  id Int @id @default(autoincrement())

  action ActivityAction
  entity ActivityEntity

  entityId Int? // clientId, investmentId, etc.

  performedById Int // Member.id
  performedBy   Member @relation(fields: [performedById], references: [id])

  branchId Int?
  branch   Branch? @relation(fields: [branchId], references: [id])

  metadata Json? // before/after, reason, extra info

  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([performedById])
  @@index([branchId])
}

//auth
enum Role {
  ADMIN
  HR
  DEV
  BRANCH_MANAGER
  REGIONAL_MANAGER
  ZONAL_MANAGER
  AGM
  EMPLOYEE
}

model User {
  id                    String                  @id @default(uuid()) @db.Uuid
  role                  Role                    @default(EMPLOYEE)
  name                  String?
  email                 String?                 @unique
  branchId              Int?
  status                Boolean                 @default(true)
  member                Member?
  ClientDocumentRequest ClientDocumentRequest[]
}

model ClientDocumentRequest {
  id Int @id @default(autoincrement())

  clientId Int
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  token       String @unique
  createdById String @db.Uuid
  createdBy   User   @relation(fields: [createdById], references: [id])

  expiresAt DateTime
  used      Boolean  @default(false)

  createdAt DateTime @default(now())

  documents ClientDocument[]
}

model ClientDocument {
  id Int @id @default(autoincrement())

  requestId Int
  request   ClientDocumentRequest @relation(fields: [requestId], references: [id])

  idFront     String?
  idBack      String?
  paymentSlip String?

  uploadedAt DateTime @default(now())
}
