generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  Active
  Inactive
}

enum ReturnFrequency {
  Monthly
  HalfYearly
  Yearly
}

model Branch {
  id          Int            @id @default(autoincrement())
  name        String
  location    String?
  // members     Member[]
  members     MemberBranch[]
  status      Status         @default(Active)
  client      Client[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  ActivityLog ActivityLog[]
  investments Investment[]
  commission  Commission[]
}

enum Title {
  // Management/Support
  ADMIN
  HR
  ACCOUNTS
  IT

  // Probation positions
  FA // probation FA
  TL // probation TL  
  BM // probation BM
  RM // probation RM
  ZM // probation ZM
  P_AGM // probation AGM

  // Permanent positions
  TRAINEE_FA
  P_FA // permanent FA
  P_TL // permanent TL
  JBM
  SBM
  JRM
  SRM
  JZM
  SZM
  AGM
}

enum PositionType {
  PROBATION
  PERMANENT
  MANAGEMENT
}

model Position {
  id              Int              @id @default(autoincrement())
  title           Title
  rank            Int              @unique
  orc             CommissionRate?
  members         Member[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  positionTargets PositionTarget[]
  salary          PositionSalary?

  type PositionType @default(PROBATION)

  isProbation  Boolean @default(false)
  isManagement Boolean @default(false) // ← excludes from ORC chain
}

model CommissionRate {
  id               Int      @id @default(autoincrement())
  positionId       Int      @unique
  position         Position @relation(fields: [positionId], references: [id])
  ratePermanent    Float    @default(0)
  rateNonPermanent Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

//Junction Table
model MemberBranch {
  id Int @id @default(autoincrement())

  memberId Int
  branchId Int

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([memberId, branchId])
}

enum EmployeeStatus {
  PROBATION
  PERMANENT
  MANAGEMENT
}

model PermanentEvaluation {
  id              Int      @id @default(autoincrement())
  memberId        Int
  member          Member   @relation(fields: [memberId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  year            Int
  month           Int
  volumeAchieved  Float
  monthlyTarget   Float
  incentiveEarned Float    @default(0)
  allowanceEarned Float    @default(0)
  incentiveHit    Boolean  @default(false)
  allowanceHit    Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@unique([memberId, year, month])
}

model MonthlyPayroll {
  id       Int    @id @default(autoincrement())
  memberId Int
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  year     Int
  month    Int

  basicSalaryPermanent Float @default(0)
  volumeAchieved       Float @default(0)
  monthlyTarget        Float

  incentiveEarned  Float @default(0)
  allowanceEarned  Float @default(0)
  orcEarned        Float @default(0)
  commissionEarned Float @default(0)

  epfDeduction Float @default(0) // employee 8% of basic
  epfEmployer  Float @default(0) // employer 12% of basic
  etfEmployer  Float @default(0) // employer 3% of basic

  incentiveHit Boolean @default(false)
  allowanceHit Boolean @default(false)

  grossPay Float @default(0) // basic + incentive + allowance + orc + commission
  netPay   Float @default(0) // grossPay - epfDeduction

  createdAt DateTime @default(now())

  @@unique([memberId, year, month])
}

model PositionSalary {
  id         Int      @id @default(autoincrement())
  positionId Int      @unique
  position   Position @relation(fields: [positionId], references: [id])

  monthlyTarget   Float // e.g. 3_000_000
  incentiveAmount Float // paid at 100% target
  allowanceAmount Float // paid at 75% target
  commRateLow     Float // e.g. 0.05 for probation=0.07
  commRateHigh    Float // e.g. 0.08 for probation=0.10
  commThreshold   Float @default(500000)

  epfEmployee Float @default(0.08)
  epfEmployer Float @default(0.12)
  etfEmployer Float @default(0.03)

  allowanceThresholdProbation Float @default(0.75)
  allowanceThresholdPermanent Float @default(1.0)

  basicSalaryPermanent Float @default(0)
  basicSalaryProbation Float @default(0)
}

//many side ekata foreign key eka / Parent has an array
model Member {
  id                     Int       @id @default(autoincrement())
  nameWithInitials       String?
  email                  String?   @unique
  empNo                  String    @unique
  epfNo                  String?
  phone                  String?
  phone2                 String?
  nic                    String?
  dob                    DateTime?
  gender                 String?
  civilStatus            String?
  address                String?
  reportingPerson        String?
  dateOfJoin             DateTime?
  appointmentLetter      String?
  confirmation           String?
  remark                 String?
  accNo                  String?
  bank                   String?
  bankBranch             String?
  totalCommission        Float     @default(0)
  profilePic             String?
  lastClientRegisteredAt DateTime?

  userId String? @unique @db.Uuid
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  status             EmployeeStatus @default(PROBATION)
  probationStartDate String?

  positionId Int
  position   Position @relation(fields: [positionId], references: [id])

  branches           MemberBranch[]
  commissions        Commission[]
  advisorInvestments Investment[]   @relation("AdvisorInvestments")
  activityLog        ActivityLog[]
  clients            Client[]
  createdClients     Client[]       @relation("CreatedByMember")

  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  monthlyEvaluations   MonthlyEvaluation[]
  permanentEvaluations PermanentEvaluation[]
  monthlyPayrolls      MonthlyPayroll[]
}

model PositionTarget {
  id           Int      @id @default(autoincrement())
  positionId   Int
  position     Position @relation(fields: [positionId], references: [id])
  periodNumber Int
  monthNumber  Int

  // Volume target
  targetAmount Float

  // Incentive (bonus)
  bonusAmount       Float
  bonusThresholdPct Float @default(1.0) // % of target required, e.g. 0.50 for BM

  // Vehicle & Fuel
  vehicleAmount       Float @default(0)
  vehicleThresholdPct Float @default(0) // e.g. 0.60 for BM

  // Team Active
  teamActiveAmount       Float @default(0)
  teamActiveThresholdPct Float @default(0) // e.g. 0.85 for BM
  minActiveAdvisors      Int   @default(0)
  minActiveFMs           Int   @default(0)
  minActiveBMs           Int   @default(0)

  // FA only
  excessRate       Float @default(0)
  partialThreshold Float @default(0)
  partialBonus     Float @default(0)

  after6MonthTarget Float @default(0)

  @@unique([positionId, periodNumber, monthNumber])
}

model MonthlyEvaluation {
  id             Int      @id @default(autoincrement())
  memberId       Int
  member         Member   @relation(fields: [memberId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  year           Int
  month          Int // 1–12
  periodNumber   Int? // 1 or 2 during probation, null if permanent
  monthInPeriod  Int? // 1, 2, 3 within period
  volumeAchieved Float
  targetAmount   Float // snapshot at time of eval
  bonusEarned    Float    @default(0)
  excessBonus    Float    @default(0)
  targetHit      Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@unique([memberId, year, month])
}

model FinancialPlan {
  id          Int          @id @default(autoincrement())
  name        String
  duration    Int // months
  rate        Float
  description String
  status      Status       @default(Active)
  investment  Float?
  investments Investment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Beneficiary {
  id           Int     @id @default(autoincrement())
  fullName     String
  nic          String?
  phone        String
  bankName     String
  bankBranch   String
  accountNo    String
  relationship String

  clientId Int
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  investments Investment[] // investments that use this beneficiary

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Nominee {
  id               Int     @id @default(autoincrement())
  fullName         String
  permanentAddress String
  postalAddress    String?

  clientId Int
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  investments Investment[] // investments that use this nominee

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Investment {
  id             Int      @id @default(autoincrement())
  refNumber      String?
  investmentDate DateTime
  amount         Float

  clientId Int
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id])

  planId Int?
  plan   FinancialPlan? @relation(fields: [planId], references: [id])

  advisorId Int?
  advisor   Member? @relation("AdvisorInvestments", fields: [advisorId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  beneficiaryId Int?
  beneficiary   Beneficiary? @relation(fields: [beneficiaryId], references: [id], onDelete: SetNull)

  nomineeId Int?
  nominee   Nominee? @relation(fields: [nomineeId], references: [id], onDelete: SetNull)

  commission           Commission[]
  profit               Profit?
  commissionsProcessed Boolean      @default(false)

  maturityDate     DateTime? // store for easy querying/filtering
  isMatured        Boolean   @default(false)
  maturityNotified Boolean   @default(false) // track if notification was sent

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id                    Int                     @id @default(autoincrement())
  fullName              String
  nic                   String?                 @unique
  drivingLicense        String?                 @unique
  passportNo            String?                 @unique
  email                 String?                 @unique
  phoneMobile           String?
  phoneLand             String?
  memberId              Int?
  member                Member?                 @relation(fields: [memberId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  dateOfBirth           DateTime?
  occupation            String?
  address               String
  investmentAmount      Int
  signature             String?
  idFront               String?
  idBack                String?
  paymentSlip           String?
  proposal              String?
  agreement             String?
  branchId              Int
  branch                Branch                  @relation(fields: [branchId], references: [id])
  status                Status                  @default(Active)
  investments           Investment[]
  beneficiaries         Beneficiary[] // ← one-to-many
  nominees              Nominee[] // ← one-to-many
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  ClientDocumentRequest ClientDocumentRequest[]
  proposalFormNo        String?                 @unique

  createdById Int?
  createdBy   Member? @relation("CreatedByMember", fields: [createdById], references: [id])
}

model Commission {
  id           Int     @id @default(autoincrement())
  refNumber    String? @unique // Optional for now to support existing data
  investmentId Int
  memberEmpNo  String
  branchId     Int

  amount    Float
  type      CommissionType
  createdAt DateTime       @default(now())

  member     Member     @relation(fields: [memberEmpNo], references: [empNo], onDelete: Cascade, onUpdate: Cascade)
  investment Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)
  Branch     Branch     @relation(fields: [branchId], references: [id])

  @@index([investmentId])
  @@index([memberEmpNo])
}

enum CommissionType {
  PERSONAL
  UPLINE
}

model Profit {
  id Int @id @default(autoincrement())

  investmentId Int        @unique
  investment   Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  investmentAmount Float @default(0)
  commissionPayout Float @default(0)
  totalProfit      Float @default(0)
}

//activity log

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  LOGIN
}

enum ActivityEntity {
  BRANCH
  CLIENT
  INVESTMENT
  COMMISSION
  PROFIT
  MEMBER
  FINANCIAL_PLAN
}

model ActivityLog {
  id Int @id @default(autoincrement())

  action ActivityAction
  entity ActivityEntity

  entityId Int? // clientId, investmentId, etc.

  performedById Int? // Member.id
  performedBy   Member? @relation(fields: [performedById], references: [id], onDelete: Cascade, onUpdate: Cascade)

  branchId Int?
  branch   Branch? @relation(fields: [branchId], references: [id])

  metadata Json? // before/after, reason, extra info

  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([performedById])
  @@index([branchId])
}

//auth
enum Role {
  ADMIN
  HR
  DEV
  BRANCH_MANAGER
  REGIONAL_MANAGER
  ZONAL_MANAGER
  AGM
  EMPLOYEE
}

model User {
  id                    String                  @id @default(uuid()) @db.Uuid
  role                  Role                    @default(EMPLOYEE)
  name                  String?
  email                 String?                 @unique
  branchId              Int?
  status                Boolean                 @default(true)
  member                Member?
  ClientDocumentRequest ClientDocumentRequest[]
}

model ClientDocumentRequest {
  id Int @id @default(autoincrement())

  clientId Int
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  token       String @unique
  createdById String @db.Uuid
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Cascade)

  expiresAt DateTime
  used      Boolean  @default(false)

  createdAt DateTime @default(now())

  documents ClientDocument[]
}

model ClientDocument {
  id Int @id @default(autoincrement())

  requestId Int
  request   ClientDocumentRequest @relation(fields: [requestId], references: [id])

  idFront     String?
  idBack      String?
  paymentSlip String?

  uploadedAt DateTime @default(now())
}
